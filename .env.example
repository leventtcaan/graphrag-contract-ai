# ─────────────────────────────────────────────────────────────────────────────
# IT Compliance & Contract Analyzer — Ortam Değişkenleri Örneği
# Bu dosyayı .env olarak kopyalayıp kendi değerlerinle doldur:
#   cp .env.example .env
# .env dosyasını asla Git'e commit etme! (.gitignore'da zaten var)
# ─────────────────────────────────────────────────────────────────────────────

# ─── Uygulama ─────────────────────────────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_STRONG_RANDOM_KEY_MIN_32_CHARS

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=itlaw_user
POSTGRES_PASSWORD=itlaw_secret
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=itlaw_db

# ─── Neo4j ────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=itlaw_neo4j_secret
# Docker Compose için (kullanıcı:şifre formatında)
NEO4J_AUTH=neo4j/itlaw_neo4j_secret

# ─── Neo4j Port'ları (Docker Compose) ─────────────────────────────────────────
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# ─── Groq / LLM ───────────────────────────────────────────────────────────────
# Ücretsiz API anahtarı: https://console.groq.com
# Groq LPU donanımı sayesinde OpenAI'dan 10-20x daha hızlı çıkarım
GROQ_API_KEY=gsk_your-api-key-here

# ─── Dosya Depolama ───────────────────────────────────────────────────────────
# Yüklenen PDF dosyalarının saklanacağı dizin (uygulama başlarken oluşturulur)
UPLOAD_DIR=downloads/contracts
